{
    "_notes": [
        "Mirrors the standard demo learning config for parametric training.",
        "Best-checkpoint selection monitors the held-out",
        "(unseen-audio/unseen-param) validation val_loss.",
        "Optional threshold_esr early stopping uses the held-out ESR metric."
    ],
    "train_dataloader": {
        "batch_size": 16,
        "shuffle": true,
        "pin_memory": true,
        "drop_last": true,
        "num_workers": 2,
        "persistent_workers": true,
        "prefetch_factor": 2
    },
    "val_dataloader": {
        "batch_size": 16,
        "num_workers": 2,
        "persistent_workers": true,
        "prefetch_factor": 2
    },
    "trainer": {
        "accelerator": "gpu",
        "devices": 1,
        "precision": "16-mixed",
        "benchmark": true,
        "max_epochs": 10
    },
    "threshold_esr": null,
    "trainer_fit_kwargs": {}
}
