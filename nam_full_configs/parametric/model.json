{
    "_notes": [
        "ParametricWaveNet example for this branch.",
        "The stock GUI trainer currently builds a PackedWaveNet container for regular A2 training.",
        "Packed parametric training is not supported on this branch, so this example keeps a single ParametricWaveNet wrapper while matching the PackedWaveNet channels_8 inner WaveNet config and training hyperparameters.",
        "For parametric runs, optimizer.lr and optimizer.weight_decay target the inner WaveNet trunk, while optimizer.adapter_lr and optimizer.adapter_weight_decay can separately target the residual adapter.",
        "params is an ordered array of {name, min, max, default} objects. Order is significant (positional net input). default is the export-time/reference operating point.",
        "Provide parameter values everywhere else in raw knob/display units. The model maps each parameter from its declared [min, max] range into an internal [-1, 1] range before the adapter sees it.",
        "adapter_gamma_scale and adapter_beta_scale keep the per-layer residual modulation bounded during training and export."
    ],
    "net": {
        "name": "ParametricWaveNet",
        "config": {
            "layers_configs": [
                {
                    "condition_size": 1,
                    "input_size": 1,
                    "channels": 8,
                    "head": {
                        "out_channels": 1,
                        "kernel_size": 16,
                        "bias": true
                    },
                    "kernel_sizes": [
                        6,
                        6,
                        6,
                        6,
                        6,
                        6,
                        6,
                        6,
                        6,
                        6,
                        6,
                        6,
                        6,
                        6,
                        15,
                        15,
                        6,
                        6,
                        6,
                        6,
                        6,
                        6,
                        6
                    ],
                    "dilations": [
                        1,
                        3,
                        7,
                        17,
                        41,
                        101,
                        239,
                        1,
                        3,
                        7,
                        17,
                        41,
                        101,
                        239,
                        1,
                        13,
                        1,
                        3,
                        7,
                        17,
                        41,
                        101,
                        239
                    ],
                    "activation": "LeakyReLU",
                    "gated": false
                }
            ],
            "adapter_hidden_dim": 8,
            "adapter_activation": "SiLU",
            "adapter_gamma_scale": 0.05,
            "adapter_beta_scale": 0.05,
            "head_scale": 0.01,
            "params": [
                {"name": "gain",   "min": 0.0, "max": 10.0, "default": 5.0},
                {"name": "bright", "min": 0.0, "max": 1.0,  "default": 0.5}
            ]
        }
    },
    "loss": {
        "val_loss": "esr",
        "mrstft_weight": 0.0005
    },
    "optimizer": {
        "lr": 0.004,
        "adapter_lr": 0.0005,
        "weight_decay": 3.17e-07,
        "adapter_weight_decay": 3.17e-07
    },
    "lr_scheduler": {
        "class": "ExponentialLR",
        "kwargs": {
            "gamma": 0.994
        }
    }
}
