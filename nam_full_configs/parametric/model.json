{
    "_notes": [
        "Parametric HyperWaveNet training config based on the packed channels_8 WaveNet.",
        "The model architecture, loss, optimizer, and scheduler match the default parametric example.",
        "Only the continuous parameter definitions are specialized for the Low/High dataset."
    ],
    "net": {
        "name": "HyperWaveNet",
        "config": {
            "layers": [
                {
                    "input_size": 1,
                    "condition_size": 1,
                    "channels": 8,
                    "kernel_sizes": [
                        6,
                        6,
                        6,
                        6,
                        6,
                        6,
                        6,
                        6,
                        6,
                        6,
                        6,
                        6,
                        6,
                        6,
                        15,
                        15,
                        6,
                        6,
                        6,
                        6,
                        6,
                        6,
                        6
                    ],
                    "dilations": [
                        1,
                        3,
                        7,
                        17,
                        41,
                        101,
                        239,
                        1,
                        3,
                        7,
                        17,
                        41,
                        101,
                        239,
                        1,
                        13,
                        1,
                        3,
                        7,
                        17,
                        41,
                        101,
                        239
                    ],
                    "activation": "LeakyReLU",
                    "gated": false,
                    "head": {
                        "out_channels": 1,
                        "kernel_size": 16,
                        "bias": true
                    }
                }
            ],
            "head_scale": 0.01,
            "params": [
                {
                    "name": "Gain",
                    "min": 0,
                    "max": 10,
                    "default": 5,
                    "type": "continuous"
                },
                {
                    "name": "Tone",
                    "min": 0,
                    "max": 10,
                    "default": 5.0,
                    "type": "continuous"
                },
                {
                    "name": "Boost",
                    "type": "switch",
                    "min": 0,
                    "max": 1,
                    "default": 0,
                    "enum_names": [
                        "Off",
                        "On"
                    ]
                }
            ],
            "hypernet": {
                "selector": {
                    "exclude_suffixes": [
                        "_conv.weight"
                    ]
                }
            }
        }
    },
    "loss": {
        "val_loss": "esr",
        "mrstft_weight": 0.0005
    },
    "optimizer": {
        "lr": 0.002,
        "weight_decay": 3.17e-07
    },
    "lr_scheduler": {
        "class": "ExponentialLR",
        "kwargs": {
            "gamma": 0.994
        }
    }
}