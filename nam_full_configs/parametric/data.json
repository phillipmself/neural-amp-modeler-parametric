{
    "_notes": [
        "Parametric config-based training example for this branch.",
        "This mirrors the GUI trainer layout where possible:",
        "- one shared input capture in common.x_path",
        "- one output capture per parameter setting",
        "- training starts 10 seconds in and stops 9 seconds before the end",
        "- the final 9 seconds are reserved for validation",
        "- optional verification captures plus verification_windows report four ESR buckets",
        "Replace the example WAV paths with your real captures."
    ],
    "type": "parametric",
    "common": {
        "x_path": "C:\\path\\to\\captures\\input.wav",
        "allow_unequal_lengths": true,
        "param_names": [
            "gain",
            "bright"
        ]
    },
    "train": [
        {
            "y_path": "C:\\path\\to\\captures\\gain_2_bright_0_output.wav",
            "delay": 0,
            "params": [
                0.2,
                0.0
            ],
            "ny": 8192,
            "start_seconds": 10.0,
            "stop_seconds": -9.0
        },
        {
            "y_path": "C:\\path\\to\\captures\\gain_5_bright_5_output.wav",
            "delay": 0,
            "params": [
                0.5,
                0.5
            ],
            "ny": 8192,
            "start_seconds": 10.0,
            "stop_seconds": -9.0
        },
        {
            "y_path": "C:\\path\\to\\captures\\gain_8_bright_10_output.wav",
            "delay": 0,
            "params": [
                0.8,
                1.0
            ],
            "ny": 8192,
            "start_seconds": 10.0,
            "stop_seconds": -9.0
        }
    ],
    "validation": [
        {
            "y_path": "C:\\path\\to\\captures\\gain_2_bright_0_output.wav",
            "delay": 0,
            "params": [
                0.2,
                0.0
            ],
            "start_seconds": -9.0,
            "ny": null
        },
        {
            "y_path": "C:\\path\\to\\captures\\gain_5_bright_5_output.wav",
            "delay": 0,
            "params": [
                0.5,
                0.5
            ],
            "start_seconds": -9.0,
            "ny": null
        },
        {
            "y_path": "C:\\path\\to\\captures\\gain_8_bright_10_output.wav",
            "delay": 0,
            "params": [
                0.8,
                1.0
            ],
            "start_seconds": -9.0,
            "ny": null
        }
    ],
    "verification_windows": {
        "seen_audio": {
            "start_seconds": -18.0,
            "stop_seconds": -9.0,
            "ny": null
        },
        "unseen_audio": {
            "start_seconds": -9.0,
            "ny": null
        }
    },
    "verification": [
        {
            "y_path": "C:\\path\\to\\captures\\gain_35_bright_2_output.wav",
            "delay": 0,
            "params": [
                0.35,
                0.2
            ]
        },
        {
            "y_path": "C:\\path\\to\\captures\\gain_65_bright_8_output.wav",
            "delay": 0,
            "params": [
                0.65,
                0.8
            ]
        }
    ],
    "joint": [
        {
            "name": "nam.data.normalize_joint_dataset_output",
            "kwargs": {
                "level_rms_dbfs": -18.0
            }
        }
    ]
}
